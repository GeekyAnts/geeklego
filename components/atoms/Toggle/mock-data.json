{
  "default": {
    "children": "Bold",
    "variant": "default",
    "size": "md",
    "defaultPressed": false
  },
  "variants": [
    { "variant": "default", "children": "Default",  "pressed": false },
    { "variant": "default", "children": "Default",  "pressed": true  },
    { "variant": "outline", "children": "Outline",  "pressed": false },
    { "variant": "outline", "children": "Outline",  "pressed": true  },
    { "variant": "ghost",   "children": "Ghost",    "pressed": false },
    { "variant": "ghost",   "children": "Ghost",    "pressed": true  }
  ],
  "sizes": [
    { "size": "sm", "children": "Small",  "variant": "outline" },
    { "size": "md", "children": "Medium", "variant": "outline" },
    { "size": "lg", "children": "Large",  "variant": "outline" }
  ],
  "states": {
    "unpressed": { "children": "Unpressed", "variant": "outline", "pressed": false },
    "pressed":   { "children": "Pressed",   "variant": "outline", "pressed": true  },
    "disabled":  { "children": "Disabled",  "variant": "outline", "disabled": true },
    "pressed_disabled": { "children": "Pressed + Disabled", "variant": "outline", "pressed": true, "disabled": true }
