{
  "name": "geeklego",
  "version": "0.1.0",
  "private": false,
  "license": "MIT",
  "type": "module",
  "description": "A React component library built on a design-system-first architecture with Tailwind CSS v4. 58 production-ready components: atoms, molecules, and organisms.",
  "keywords": [
    "react",
    "component-library",
    "design-system",
    "tailwind",
    "typescript",
    "ui"
  ],
  "homepage": "https://geeklego.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/geeklego/geeklego.git"
  },
  "bugs": {
    "url": "https://github.com/geeklego/geeklego/issues"
  },
  "author": "Geeklego",
  "engines": {
    "node": ">=20.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./catalog": {
      "types": "./dist/catalog.d.ts",
      "import": "./dist/catalog.js",
      "require": "./dist/catalog.cjs"
    },
    "./styles": {
      "types": "./dist/styles.d.ts",
      "style": "./dist/geeklego.css",
      "import": "./dist/geeklego.css",
      "require": "./dist/geeklego.css"
    },
    "./styles-source": {
      "types": "./dist/styles-source.d.ts",
      "style": "./design-system/geeklego.css",
      "import": "./design-system/geeklego.css",
      "require": "./design-system/geeklego.css"
    }
  },
  "scripts": {
    "predev": "node -e \"try{require('esbuild')}catch(e){console.error('\\nesbuild binary mismatch — attempting auto-fix...\\n');try{require('child_process').execSync('pnpm rebuild esbuild',{stdio:'inherit'})}catch(e2){console.error('\\nAuto-fix failed. Run manually:\\n  pnpm store prune\\n  rm -rf node_modules packages/geeklego/node_modules apps/geeklego-site/node_modules\\n  pnpm install\\n');process.exit(1)}}\"",
    "dev": "vite --config vite.config.ts app",
    "dev:all": "concurrently -n \"tokens,storybook\" -c \"cyan,magenta\" --delay 2 \"vite --config vite.config.ts app\" \"storybook dev -p 6006\"",
    "prestorybook": "node -e \"try{require('esbuild')}catch(e){console.error('\\nesbuild binary mismatch — attempting auto-fix...\\n');try{require('child_process').execSync('pnpm rebuild esbuild',{stdio:'inherit'})}catch(e2){console.error('\\nAuto-fix failed. Run manually:\\n  pnpm store prune\\n  rm -rf node_modules packages/geeklego/node_modules apps/geeklego-site/node_modules\\n  pnpm install\\n');process.exit(1)}}\"",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "validate-tokens": "npx tsx scripts/validate-tokens.ts",
    "lint-css": "stylelint --config .stylelintrc.mjs design-system/geeklego.css",
    "build": "tsup && npm run build:css",
    "build:css": "tailwindcss -i ./design-system/geeklego.css -o ./dist/geeklego.css --minify"
  },
  "peerDependencies": {
    "lucide-react": ">=0.400.0 || >=1.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.2.19",
    "@storybook/addon-docs": "^10.2.19",
    "@storybook/addon-vitest": "^10.2.19",
    "@storybook/react-vite": "^10.2.19",
    "@tailwindcss/cli": "^4.2.4",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/browser-playwright": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "playwright": "^1.58.2",
    "storybook": "^10.2.19",
    "stylelint": "^16.0.0",
    "tailwindcss": "^4.2.1",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.0"
  },
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Safari versions",
    "last 2 Edge versions",
    "not dead"
  ]
}
