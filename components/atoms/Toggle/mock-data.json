  "edge_cases": {
    "icon_only": {
      "children": "(icon node)",
      "aria-label": "Bold",
      "variant": "outline",
      "note": "No visible text — aria-label is the accessible name"
    },
    "long_label": {
      "children": "Toggle the advanced formatting options",
      "variant": "outline",
      "note": "content-nowrap clips with ellipsis before wrapping"
    },
    "empty_children": {
      "children": null,
      "aria-label": "Action",
      "variant": "default",
      "note": "Children is null — aria-label is mandatory here"
    },
    "icon_and_text": {
      "children": "(icon + 'Grid view')",
      "variant": "outline",
      "pressed": false
    }
  }
